generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(cuid())  // cuid is better than autoincrement for public IDs
  name      String
  email     String
  message   String
  read      Boolean  @default(false)       // track if you've seen it
  createdAt DateTime @default(now())
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique  // URL-friendly version: "my-first-post"
  excerpt     String            // Short summary shown on blog list
  content     String            // Full markdown content
  published   Boolean  @default(false)  // draft until you publish
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  source    String
  title     String
  content   String
  embedding Unsupported("vector(3072)")?
  createdAt DateTime @default(now())
}